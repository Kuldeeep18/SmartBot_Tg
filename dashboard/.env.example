# Dashboard database URI
MONGODB_URI="mongodb://anjani:mypasswd@localhost:27017"

# Encryption key for securing tokens (must be 32 bytes/characters long)
ENCRYPTION_KEY="replace-this-with-a-random-32char-string"

# Shared Telegram developer credentials (used by all spawned bots)
API_ID=""
API_HASH=""

# MongoDB connection string to pass to individual bots. 
# {HASH} will be replaced with a unique deterministic ID for each bot's database.
# E.g., if bots are running in the same Docker Compose network as the main MongoDB database:
DB_URI_TEMPLATE="mongodb://anjani:mypasswd@mongo/anjani_{HASH}?authSource=admin"

# Docker bridge network name. Needs to be the network where the MongoDB container runs.
# In a typical compose setup, it will be "anjani_default" or "anjani-master_default".
DOCKER_NETWORK="anjani_default"
