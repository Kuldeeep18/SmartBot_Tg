# Telegram Bot Configuration
TELEGRAM_BOT_TOKEN=your_telegram_bot_token_here

# Gemini API Configuration
GEMINI_API_KEY=your_gemini_api_key_here

# GitHub Token (Optional - for private repos or rate limit avoidance)
GITHUB_TOKEN=your_github_pat_here

# Configuration limits
MAX_REPO_SIZE_MB=100

# GitHub OAuth Configuration (For PR Merge & Close)
# Create a free OAuth App in GitHub Developer Settings
GITHUB_CLIENT_ID=your_github_client_id_here
GITHUB_CLIENT_SECRET=your_github_client_secret_here
# Callback redirect URL (must match the one registered in GitHub)
OAUTH_REDIRECT_URL=http://localhost:3000/oauth/callback
PORT=3000
