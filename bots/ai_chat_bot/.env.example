# ============================================
# Telegram Bot Configuration
# ============================================
TELEGRAM_BOT_TOKEN=your-telegram-bot-token

# ============================================
# Supabase Configuration (Vector Store)
# ============================================
SUPABASE_URL=your-supabase-url
SUPABASE_SERVICE_ROLE_KEY=your-supabase-service-role-key

# ============================================
# LLM Provider Configuration
# ============================================
# Options: openai | gemini | groq | openrouter
LLM_PROVIDER=openai
LLM_MODEL=gpt-4o-mini
EMBEDDING_MODEL=text-embedding-3-small

# ============================================
# API Keys — fill in the one matching your LLM_PROVIDER
# ============================================
OPENAI_API_KEY=your-openai-api-key
GOOGLE_API_KEY=
GROQ_API_KEY=
OPENROUTER_API_KEY=

# ============================================
# LangChain Tracing (Optional — for debugging)
# ============================================
LANGCHAIN_TRACING_V2=false
LANGCHAIN_API_KEY=
LANGCHAIN_PROJECT=telegram-pdf-chatbot

# ============================================
# RAG Configuration
# ============================================
CHUNK_SIZE=1000
CHUNK_OVERLAP=200
RETRIEVER_K=5
